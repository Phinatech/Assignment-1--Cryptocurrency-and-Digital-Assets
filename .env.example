# ============================================================
#  .env.example — Environment Variables for Testnet Deployment
#
#  Steps:
#  1. Copy this file:    cp .env.example .env
#  2. Fill in the values below
#  3. NEVER commit .env to GitHub — it is already in .gitignore
# ============================================================

# Private key of the wallet that will deploy the contracts.
# Get a testnet wallet from MetaMask (copy the private key from
# Account Details → Export Private Key).
# WARNING: Never use a wallet that holds real ETH for this.
SEPOLIA_PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# Sepolia RPC URL — get a free endpoint from:
#   https://www.alchemy.com   (create a free account → New App → Ethereum Sepolia)
#   https://infura.io          (create free account → Create New Key → Sepolia)
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_API_KEY
